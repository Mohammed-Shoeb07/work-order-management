@page
@model WorkOrderManagement.Pages.WorkOrders.CreateModel

<div style="font-family:Arial;padding:30px;max-width:650px;">
    <h1 style="margin-bottom:25px;">Create Work Order</h1>

    <form method="post" style="background-color:#f9fafb;border:1px solid #d1d5db;padding:22px;border-radius:8px;">

        <div asp-validation-summary="All"
             style="color:#dc2626;margin-bottom:16px;">
        </div>

        <div style="margin-bottom:16px;">
            <label style="font-weight:bold;">Title</label><br />
            <input asp-for="WorkOrder.Title"
                   required
                   style="width:100%;padding:10px;border:1px solid #9ca3af;border-radius:5px;margin-top:5px;" />
        </div>

        <div style="margin-bottom:16px;">
            <label style="font-weight:bold;">Description</label><br />
            <textarea asp-for="WorkOrder.Description"
                      required
                      rows="5"
                      style="width:100%;padding:10px;border:1px solid #9ca3af;border-radius:5px;margin-top:5px;"></textarea>
        </div>

        <div style="margin-bottom:16px;">
            <label style="font-weight:bold;">Department</label><br />
            <input asp-for="WorkOrder.Department"
                   required
                   style="width:100%;padding:10px;border:1px solid #9ca3af;border-radius:5px;margin-top:5px;" />
        </div>

        <div style="margin-bottom:22px;">
            <label style="font-weight:bold;">Status</label><br />
            <select asp-for="WorkOrder.Status"
                    required
                    style="width:100%;padding:10px;border:1px solid #9ca3af;border-radius:5px;margin-top:5px;">
                <option>Open</option>
                <option>In Progress</option>
                <option>Completed</option>
            </select>
        </div>

        <button type="submit"
                style="background-color:#2563eb;color:white;padding:10px 16px;border:none;border-radius:6px;font-weight:bold;cursor:pointer;">
            Create
        </button>

        <a asp-page="/WorkOrders/Index"
           style="margin-left:12px;color:#374151;text-decoration:none;font-weight:bold;">
            Cancel
        </a>
    </form>
</div>