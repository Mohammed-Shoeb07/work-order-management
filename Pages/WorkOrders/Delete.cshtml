@page
@model WorkOrderManagement.Pages.WorkOrders.DeleteModel

<h1 style="color:red;margin-bottom:20px;">
    Delete Work Order
</h1>

<div style="font-family:Arial;
            max-width:500px;">

    <p>
        Are you sure you want to delete this work order?
    </p>

    <div style="border:1px solid #ccc;
                padding:15px;
                margin-bottom:20px;">

        <p>
            <strong>Title:</strong>
            @Model.WorkOrder.Title
        </p>

        <p>
            <strong>Department:</strong>
            @Model.WorkOrder.Department
        </p>

        <p>
            <strong>Status:</strong>
            @Model.WorkOrder.Status
        </p>

    </div>

    <form method="post">

        <input type="hidden"
               asp-for="WorkOrder.Id" />

        <button type="submit"
                style="padding:10px 15px;
                       background-color:#dc2626;
                       color:white;
                       border:none;
                       border-radius:5px;">

            Delete

        </button>

        <a asp-page="/WorkOrders/Index"
           style="margin-left:10px;">

            Cancel

        </a>

    </form>

</div>